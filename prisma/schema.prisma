generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  MEMBER
}

enum ProjectStatus {
  DESIGN
  DEV
  DONE
}

enum TimelineEventType {
  MILESTONE
  DESIGN
  DEPLOY
  ROCKET
  MANUAL
}

enum TimelineEventStatus {
  COMPLETED
  CURRENT
  PENDING
}

enum TimelineEventSource {
  GITHUB
  VERCEL
  FIGMA
  MANUAL
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  PRAISE
  NEW_INTEGRATION
}

enum IntegrationProvider {
  GITHUB
  VERCEL
  FIGMA
  SLACK
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
}

model User {
  id            String             @id @db.Uuid
  email         String             @unique
  name          String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  organizations UserOrganization[]
  feedbacks     Feedback[]

  @@map("User")
}

model Organization {
  id             String                    @id @default(uuid()) @db.Uuid
  name           String
  createdAt      DateTime                  @default(now()) @map("created_at")
  members        UserOrganization[]
  clients        Client[]
  projects       Project[]
  integrations   OrganizationIntegration[]

  @@map("Organization")
}

model OrganizationIntegration {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  provider       IntegrationProvider
  accessToken    String?             @map("access_token")
  status         IntegrationStatus   @default(DISCONNECTED)
  connectedAt    DateTime?           @map("connected_at")
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@map("OrganizationIntegration")
}

model UserOrganization {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  role           OrgRole      @default(OWNER)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("UserOrganization")
}

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  email          String
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects       Project[]

  @@unique([organizationId, email])
  @@map("Client")
}

model Project {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  clientId       String            @map("client_id") @db.Uuid
  name           String
  description    String?
  status         ProjectStatus     @default(DESIGN)
  progress       Int               @default(0)
  slug           String            @unique
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  milestones     Milestone[]
  timelineEvents TimelineEvent[]

  @@map("Project")
}

model Milestone {
  id          String  @id @default(uuid()) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  title       String
  description String?
  completed   Boolean @default(false)
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("Milestone")
}

model TimelineEvent {
  id          String              @id @default(uuid()) @db.Uuid
  projectId   String              @map("project_id") @db.Uuid
  title       String
  description String?
  type        TimelineEventType   @default(MANUAL)
  status      TimelineEventStatus @default(CURRENT)
  source      TimelineEventSource @default(MANUAL)
  createdAt   DateTime            @default(now()) @map("created_at")
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("TimelineEvent")
}

model Feedback {
  id        String           @id @default(uuid()) @db.Uuid
  message   String
  category  FeedbackCategory
  userId    String           @map("user_id") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Feedback")
}
